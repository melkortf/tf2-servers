ARG REGISTRY=ghcr.io
ARG TF2_BASE_TAG=latest
ARG ARCH=i386

FROM ubuntu:22.04 AS plugins
WORKDIR /download
ARG INSTALL_DIR=/server/tf
RUN mkdir -p "${INSTALL_DIR}"

ARG METAMOD_VERSION=1.12.0-git1224
ARG METAMOD_RELEASE_TAG=1.12.0.1224
ARG METAMOD_FILE_NAME=mmsource-${METAMOD_VERSION}-linux.tar.gz
ARG METAMOD_URL=https://github.com/alliedmodders/metamod-source/releases/download/${METAMOD_RELEASE_TAG}/${METAMOD_FILE_NAME}
ARG METAMOD_CHECKSUM=004431fd1423fe2b07a8369ceb4214caa53ffee06fca7cc779f2d1d8cb934620
ADD --checksum=sha256:${METAMOD_CHECKSUM} ${METAMOD_URL} .
RUN tar xf "${METAMOD_FILE_NAME}" -C "${INSTALL_DIR}/"

ARG SOURCEMOD_VERSION=1.12.0-git7236
ARG SOURCEMOD_RELEASE_TAG=1.12.0.7236
ARG SOURCEMOD_FILE_NAME=sourcemod-${SOURCEMOD_VERSION}-linux.tar.gz
ARG SOURCEMOD_URL=https://github.com/alliedmodders/sourcemod/releases/download/${SOURCEMOD_RELEASE_TAG}/${SOURCEMOD_FILE_NAME}
ARG SOURCEMOD_CHECKSUM=db357f27ea405720fa8ecd818fefe23db075973a506ba045307f03ba31d508ab
ADD --checksum=sha256:${SOURCEMOD_CHECKSUM} ${SOURCEMOD_URL} .
RUN tar xf "${SOURCEMOD_FILE_NAME}" -C "${INSTALL_DIR}/"

FROM ${REGISTRY}/melkortf/tf2-base/${ARCH}:${TF2_BASE_TAG}
LABEL maintainer="garrappachc@gmail.com"

ARG INSTALL_DIR=/server/tf
COPY --from=plugins --chown=tf2 "${INSTALL_DIR}/" "${SERVER_DIR}/tf/"
